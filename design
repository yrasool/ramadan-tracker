    </div>
  </div>
</div>

<div id="room-names" class="room" style="background:linear-gradient(180deg,#020c0c,#010808)">
  <div class="z-band"></div>
  <div class="room-topbar">
    <button class="back-btn" onclick="closeRoom('names')">← Courtyard</button>
    <div class="room-title-block">
      <span class="rtitle-ar" style="color:#80ffff;text-shadow:0 0 20px #80ffff">أسماء الله الحُسنى</span>
      <span class="rtitle-en" style="color:#50d0d0">The Beautiful Names of Allah</span>
      <span class="rday-lbl" id="names-day-lbl" style="color:#80ffff"></span>
    </div>
    <div style="width:120px"></div>
  </div>
  <div class="room-content">
    <div class="fsec"><div class="fsec-title" style="color:#80ffff">Names Learned Today</div>
