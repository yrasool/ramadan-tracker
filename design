   glow:'rgba(139,34,60,.9)',glowD:'rgba(60,10,20,.5)'},
  {id:'memorize',ar:'الحِفظ',en:'Memorization',
   zelC1:'#100820',zelC2:'#3a1a70',zelC3:'#8060d0',zelAcc:'#f5c842',
   panC1:'#200c40',panC2:'#100820',panStr:'#7050c0',panKnk:'#9070d0',
