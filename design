// ─── STATE ───
const RAMADAN_START=new Date(2026,1,19);
const TOTAL_DAYS=30;
const USERS=['Yusra','Zaminah'];
const PRESET_ZIKR=[
  {key:'SubhanAllah',ar:'سُبحانَ الله',en:'SubhanAllah'},
  {key:'Alhamdulillah',ar:'الحَمدُ لله',en:'Alhamdulillah'},
  {key:'AllahuAkbar',ar:'اللهُ أكبَر',en:'Allahu Akbar'},
  {key:'Astaghfirullah',ar:'أستَغفِرُ الله',en:'Astaghfirullah'},
];
const today=new Date(2026,1,20);
function getDayNum(d){const s=new Date(RAMADAN_START);s.setHours(0,0,0,0);const t=new Date(d);t.setHours(0,0,0,0);return Math.floor((t-s)/86400000)+1;}
function getDayDate(n){const d=new Date(RAMADAN_START);d.setDate(d.getDate()+n-1);return d.toLocaleDateString('en-US',{month:'short',day:'numeric'});}
const todayNum=getDayNum(today);
let currentUser='Yusra',currentDay=todayNum;
let allData={};
try{allData=JSON.parse(localStorage.getItem('rm2026v3')||'{}');}catch(e){}
function emptyDay(){return{zikr:Object.fromEntries(PRESET_ZIKR.map(z=>[z.key,''])),customZikr:[{name:'',count:''},{name:'',count:''}],quranPages:'',quranJuz:'',surahsRecited:'',surahsMemorizing:'',namesOfAllah:''};}
function getDay(u,d){return allData?.[u]?.[d]?JSON.parse(JSON.stringify(allData[u][d])):emptyDay();}
function ensureDay(){if(!allData[currentUser])allData[currentUser]={};if(!allData[currentUser][currentDay])allData[currentUser][currentDay]=emptyDay();}
function saveField(f,v){ensureDay();allData[currentUser][currentDay][f]=v;persist();updateProgress();}
function saveZikr(k,v){ensureDay();allData[currentUser][currentDay].zikr[k]=v;persist();updateProgress();}
function saveCustom(i,k,v){ensureDay();const cz=allData[currentUser][currentDay].customZikr||[{name:'',count:''},{name:'',count:''}];cz[i]={...cz[i],[k]:v};allData[currentUser][currentDay].customZikr=cz;persist();}
function persist(){try{localStorage.setItem('rm2026v3',JSON.stringify(allData));}catch(e){}}
function setUser(u){currentUser=u;document.querySelectorAll('.user-pill').forEach(b=>b.classList.toggle('active',b.textContent.trim()===u));updateProgress();refreshDays();}
function calcProgress(u){let f=0,t=0;for(let d=1;d<=todayNum;d++){const day=getDay(u,d);PRESET_ZIKR.forEach(z=>{t++;if(day.zikr[z.key])f++;});t++;if(day.quranPages)f++;t++;if(day.namesOfAllah)f++;}return t===0?0:Math.round(f/t*100);}
function updateProgress(){USERS.forEach(u=>{const p=calcProgress(u),k=u.toLowerCase();const ef=document.getElementById('prog-'+k),ep=document.getElementById('pct-'+k);if(ef)ef.style.width=p+'%';if(ep)ep.textContent=p+'%';});}
function refreshDays(){const strip=document.getElementById('day-strip');strip.innerHTML='';for(let d=1;d<=TOTAL_DAYS;d++){const b=document.createElement('button');b.className='dp'+(d===currentDay?' selected':(d===todayNum?' today':''))+(d>todayNum?' future':'');b.innerHTML='<div>'+getDayDate(d)+'</div><div style="font-weight:600">'+d+'</div>';if(d<=todayNum)b.onclick=(()=>{const dd=d;return()=>selectDay(dd)})();strip.appendChild(b);}}
function selectDay(d){currentDay=d;refreshDays();const or=document.querySelector('.room.active');if(or)populateRoom(or.id.replace('room-',''));}
function openRoom(id){const door=document.getElementById('door-'+id);door.classList.add('open');setTimeout(()=>{document.getElementById('courtyard').style.display='none';document.getElementById('room-'+id).classList.add('active');populateRoom(id);window.scrollTo(0,0);},820);}
function closeRoom(id){document.getElementById('room-'+id).classList.remove('active');document.getElementById('courtyard').style.display='flex';setTimeout(()=>document.getElementById('door-'+id).classList.remove('open'),100);window.scrollTo(0,0);}
function dayLabel(){return'Day '+currentDay+' · '+getDayDate(currentDay)+' · '+currentUser;}
function populateRoom(id){
  const d=getDay(currentUser,currentDay);
  if(id==='zikr'){
    document.getElementById('zikr-day-lbl').textContent=dayLabel();
    const grid=document.getElementById('zikr-grid');grid.innerHTML='';
    PRESET_ZIKR.forEach(z=>{const c=document.createElement('div');c.className='zcard';c.style.background='rgba(26,58,122,.18)';
      c.innerHTML=`<span class="zar" style="color:#a8e0ff">${z.ar}</span><span class="zen" style="color:#6090b8">${z.en}</span><input class="zinput" type="number" min="0" placeholder="0" value="${d.zikr[z.key]||''}" oninput="saveZikr('${z.key}',this.value)"/>`;grid.appendChild(c);});
    const area=document.getElementById('custom-zikr-area');area.innerHTML='';
    const cz=d.customZikr||[{name:'',count:''},{name:'',count:''}];
    [0,1].forEach(i=>{const r=document.createElement('div');r.className='czwrap';r.innerHTML=`<input class="big-input" style="flex:1" placeholder="Your zikr name..." value="${cz[i]?.name||''}" oninput="saveCustom(${i},'name',this.value)"/><input class="big-input" style="width:100px;flex-shrink:0" type="number" min="0" placeholder="0" value="${cz[i]?.count||''}" oninput="saveCustom(${i},'count',this.value)"/>`;area.appendChild(r);});
  }
  if(id==='quran'){document.getElementById('quran-day-lbl').textContent=dayLabel();document.getElementById('quran-pages').value=d.quranPages||'';document.getElementById('quran-juz').value=d.quranJuz||'';}
  if(id==='surahs'){document.getElementById('surahs-day-lbl').textContent=dayLabel();document.getElementById('surahs-recited').value=d.surahsRecited||'';}
  if(id==='memorize'){document.getElementById('memo-day-lbl').textContent=dayLabel();document.getElementById('surahs-memorizing').value=d.surahsMemorizing||'';}
  if(id==='names'){document.getElementById('names-day-lbl').textContent=dayLabel();document.getElementById('names-allah').value=d.namesOfAllah||'';}
}
updateProgress();refreshDays();
['✦','✧','⋆','·','✵'].forEach((s,i)=>{const el=document.createElement('div');el.className='float-star';el.textContent=s;el.style.cssText=`left:${8+i*18}vw;animation-duration:${14+i*3}s;animation-delay:${i*2.5}s;font-size:${7+i%3*5}px;color:#f5c842`;document.body.appendChild(el);});
</script>
