  </svg>

  <div style="padding:0 20px;text-align:center;">
    <span class="arabic-main">رَمَضَان مُبَارَك</span>
    <div class="en-title">Ramadan Mubarak · 1447 H</div>
    <div class="sub-date">19 Feb – 20 Mar · 2026</div>
  </div>

  <div class="divider"><div class="dline"></div><span class="dstar">✦</span><div class="dline"></div><span class="dstar">✧</span><div class="dline"></div><span class="dstar">✦</span><div class="dline"></div></div>

  <div class="user-bar">
    <button class="user-pill active" onclick="setUser('Yusra')">Yusra</button>
    <button class="user-pill" onclick="setUser('Zaminah')">Zaminah</button>
  </div>

  <div class="progress-row">
    <div class="pc">
      <div class="pc-name">يُسرى <span id="pct-yusra">0%</span></div>
      <div class="pc-track"><div class="pc-fill" id="prog-yusra" style="background:linear-gradient(90deg,#8a6020,#f5c842);width:0%"></div></div>
    </div>
    <div class="pc">
      <div class="pc-name">زمينة <span id="pct-zaminah">0%</span></div>
      <div class="pc-track"><div class="pc-fill" id="prog-zaminah" style="background:linear-gradient(90deg,#1a6a4a,#4adea0);width:0%"></div></div>
    </div>
  </div>

  <div class="day-strip" id="day-strip"></div>

  <div class="enter-ar">ادخل حجرة</div>
  <div class="enter-en">Enter a Chamber</div>

  <div class="doors-grid" id="doors-grid"></div>
</div>

<!-- ROOMS -->
<div id="room-zikr" class="room" style="background:linear-gradient(180deg,#030c1a,#050a14)">
  <div class="z-band"></div>
  <div class="room-topbar">
    <button class="back-btn" onclick="closeRoom('zikr')">← Courtyard</button>
    <div class="room-title-block">
      <span class="rtitle-ar" style="color:#7ad8ff;text-shadow:0 0 20px #7ad8ff">الذِّكر</span>
      <span class="rtitle-en" style="color:#50b0e0">Chamber of Zikr</span>
      <span class="rday-lbl" id="zikr-day-lbl" style="color:#7ad8ff"></span>
    </div>
    <div style="width:120px"></div>
  </div>
  <div class="room-content">
    <div class="fsec"><div class="fsec-title" style="color:#7ad8ff">Daily Remembrance</div><div class="zikr-grid" id="zikr-grid"></div></div>
    <div class="fsec"><div class="fsec-title" style="color:#7ad8ff">Custom Zikr</div><div id="custom-zikr-area" style="display:flex;flex-direction:column;gap:12px"></div></div>
  </div>
</div>

<div id="room-quran" class="room" style="background:linear-gradient(180deg,#030f06,#040b04)">
  <div class="z-band"></div>
  <div class="room-topbar">
    <button class="back-btn" onclick="closeRoom('quran')">← Courtyard</button>
    <div class="room-title-block">
      <span class="rtitle-ar" style="color:#80ffaa;text-shadow:0 0 20px #80ffaa">القُرآن</span>
      <span class="rtitle-en" style="color:#50d070">Chamber of Quran</span>
      <span class="rday-lbl" id="quran-day-lbl" style="color:#80ffaa"></span>
    </div>
    <div style="width:120px"></div>
  </div>
  <div class="room-content">
    <div class="fsec"><div class="fsec-title" style="color:#80ffaa">Today's Recitation</div>
      <div class="input-row">
        <div><label class="flabel" style="color:#50d070">Pages Read</label><input class="big-input" type="number" min="0" placeholder="0" id="quran-pages" oninput="saveField('quranPages',this.value)"/></div>
        <div><label class="flabel" style="color:#50d070">Juz Number</label><input class="big-input" type="number" min="1" max="30" placeholder="1" id="quran-juz" oninput="saveField('quranJuz',this.value)"/></div>
      </div>
    </div>
  </div>
</div>

<div id="room-surahs" class="room" style="background:linear-gradient(180deg,#100408,#0a0306)">
  <div class="z-band"></div>
  <div class="room-topbar">
    <button class="back-btn" onclick="closeRoom('surahs')">← Courtyard</button>
    <div class="room-title-block">
      <span class="rtitle-ar" style="color:#ffb8a8;text-shadow:0 0 20px #ffb8a8">السُّوَر المَتلُوَّة</span>
      <span class="rtitle-en" style="color:#e08878">Surahs Recited</span>
      <span class="rday-lbl" id="surahs-day-lbl" style="color:#ffb8a8"></span>
    </div>
    <div style="width:120px"></div>
  </div>
  <div class="room-content">
    <div class="fsec"><div class="fsec-title" style="color:#ffb8a8">Which Surahs did you recite?</div>
      <textarea class="big-input" rows="8" placeholder="e.g. Al-Fatiha, Al-Baqarah 1–5, Al-Mulk..." id="surahs-recited" oninput="saveField('surahsRecited',this.value)"></textarea>
    </div>
  </div>
</div>

<div id="room-memorize" class="room" style="background:linear-gradient(180deg,#080414,#05020c)">
  <div class="z-band"></div>
  <div class="room-topbar">
    <button class="back-btn" onclick="closeRoom('memorize')">← Courtyard</button>
    <div class="room-title-block">
      <span class="rtitle-ar" style="color:#c8b0ff;text-shadow:0 0 20px #c8b0ff">الحِفظ</span>
      <span class="rtitle-en" style="color:#9878e0">Memorization</span>
      <span class="rday-lbl" id="memo-day-lbl" style="color:#c8b0ff"></span>
    </div>
    <div style="width:120px"></div>
  </div>
  <div class="room-content">
